# Required: Text extraction via Sonnet Batch API
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GPT vision backend
OPENAI_API_KEY=sk-...

# Optional: Gemini vision backend
GOOGLE_API_KEY=AIza...

# Optional: MedGemma on GCP Vertex AI
GOOGLE_CLOUD_PROJECT=your-project-id
VERTEX_LOCATION=us-central1

# Optional: Grok vision backend (future)
XAI_API_KEY=xai-...

# Data paths (override defaults)
# CXR_MVP_DATA_DIR=./data
# CXR_MVP_OUTPUT_DIR=./output
